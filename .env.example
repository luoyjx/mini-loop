# --- LLM (required for real runs) ------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx
MODEL_ID=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # for Anthropic-compatible providers

# --- Run with no API key (deterministic fake model) -------------------------
# MINILOOP_FAKE_LLM=1
# MINILOOP_FAKE_DELAY=0.3      # simulate latency to see sessions overlap

# --- Server -----------------------------------------------------------------
# HOST=127.0.0.1
# PORT=8000

# --- Features (s03-s20) -----------------------------------------------------
# MINILOOP_FEATURES=all          # comprehensive registry + lifecycle injectors
# FALLBACK_MODEL_ID=claude-haiku-4-5-20251001   # error-recovery fallback after repeated 529s
# MINILOOP_MEMORY_ROOT=./workspaces/.memory      # shared cross-session memory
# MINILOOP_REPO_ROOT=/path/to/git/repo           # enables task-bound worktree operations
# MINILOOP_TEAM_IDLE_POLL=1.0
# MINILOOP_TEAM_IDLE_TIMEOUT=60

# --- Agent / concurrency knobs (all optional) -------------------------------
# MINILOOP_MAX_CONCURRENT_LLM=8     # global cap on simultaneous LLM calls
# MINILOOP_MAX_TURNS=50             # hard ceiling on main-loop rounds
# MINILOOP_SUBAGENT_MAX_ROUNDS=30
# MINILOOP_MAX_TOKENS=8000
# MINILOOP_TOKEN_THRESHOLD=100000   # auto-compaction trigger
# MINILOOP_BASH_TIMEOUT=120
# MINILOOP_WORKSPACE_ROOT=./workspaces
# MINILOOP_SKILLS_DIR=./skills

# --- Durable trajectories (enabled by default) -----------------------------
# MINILOOP_TRAJECTORIES=1
# MINILOOP_TRAJECTORY_ROOT=./workspaces/.trajectories
# MINILOOP_TRAJECTORY_CAPTURE_CONTENT=1  # 0 keeps structure/timing but redacts content
